# FitTrack AI - backend environment variables
# Copy to ".env" (loaded by your shell or Render dashboard) and fill in values.

# LLM provider for the coaching narrative + risk acknowledgement.
#   "auto"   - prefer OpenAI if OPENAI_API_KEY is set, else Gemini if GEMINI_API_KEY is set, else fall back to template.
#   "openai" - force OpenAI; falls back to template if no key.
#   "gemini" - force Google Gemini; falls back to template if no key.
#   "off"    - skip LLM entirely and always use the deterministic template.
FITTRACK_LLM_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (Generative Language API)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
